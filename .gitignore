# ============================================================
# Python (backend/)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Virtual environments - covers both `venv` and `.venv` naming, since both
# show up depending on how each contributor created theirs.
.venv/
venv/
env/
ENV/

# Environment files - never commit real secrets/connection strings.
# .env.example is the one exception, intentionally tracked as a template.
.env
.env.*
*.env
!.env.example

# ============================================================
# Node / frontend/
# ============================================================
node_modules/
dist/
dist-ssr/
.vite/
.vite-inspect/
*.local
*.tsbuildinfo
.eslintcache

# ============================================================
# Celery
# ============================================================
celerybeat-schedule
celerybeat.pid
celerybeat-schedule.db

# ============================================================
# ML artifacts - regenerated locally via `train_pipeline.py`, not source.
# See backend/app/ml/README.md for how to produce these.
# ============================================================
backend/app/ml/*.joblib
backend/app/ml/*.pkl
backend/app/ml/training_report.json
backend/app/ml/*.log

# ============================================================
# Docker / infra
# ============================================================
infra/postgres_data/
infra/.env
*.pid

# ============================================================
# Editors / IDEs
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ============================================================
# OS-generated files
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================
# Logs / runtime artifacts
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.pid.lock

# ============================================================
# Jupyter (in case notebooks get used for ad-hoc ML exploration)
# ============================================================
.ipynb_checkpoints/

# ============================================================
# Misc build/output dirs that shouldn't be tracked
# ============================================================
*.tgz
*.tar.gz
.cache/